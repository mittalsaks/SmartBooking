generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NotificationStatus {
  pending
  sent
  failed
}

model User {
  id          Int               @id @default(autoincrement())
  email       String            @unique
  phone       String?           @unique
  name        String?
  password    String
  isAdmin     Boolean           @default(false)
  preferences UserPreference?
  notifications Notification[]  @relation("userNotifications")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Notification {
  id          Int               @id @default(autoincrement())
  user        User?             @relation(fields: [userId], references: [id], name: "userNotifications")
  userId      Int?
  type        String
  channel     String
  subject     String?
  body        String?
  payload     Json?
  status      NotificationStatus @default(pending)
  sentAt      DateTime?
  error       String?
  retries     Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model UserPreference {
  id                 Int      @id @default(autoincrement())
  user               User     @relation(fields: [userId], references: [id])
  userId             Int      @unique
  notificationTypes  String[] @default(["registration","otp","booking_confirmation","booking_cancellation","offer_reminder","expiry_alert","new_offer"])
  notificationChannels String[] @default(["email","sms","whatsapp"])
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}
